        <mxCell id="XVpXwge4tEaLQkQ7s_Ao-9" parent="yTbIHpJ8J5dq3mqsVifV-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="If done PCA so instability under multicolinearity not a concern." vertex="1">
          <mxGeometry height="50" width="100" x="-320" y="840" as="geometry" />
        </mxCell>
        <mxCell id="XVpXwge4tEaLQkQ7s_Ao-10" parent="yTbIHpJ8J5dq3mqsVifV-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="If done VIF and moderate multicollinearity remains." vertex="1">
          <mxGeometry height="60" width="100" x="-50" y="840" as="geometry" />
        </mxCell>
        <mxCell id="XVpXwge4tEaLQkQ7s_Ao-11" parent="yTbIHpJ8J5dq3mqsVifV-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="If done close to no pre-processing of features, multicollinearity still concern." vertex="1">
          <mxGeometry height="65" width="110" x="210" y="840" as="geometry" />
        </mxCell>
        <mxCell id="XVpXwge4tEaLQkQ7s_Ao-13" parent="yTbIHpJ8J5dq3mqsVifV-1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" value="Use cross validation to obtain penalty coefficient:&lt;div&gt;1) Define a grid of lambda values&lt;/div&gt;&lt;div&gt;2) Split data into k-folds. For each fold, fit the model on k-1 other folds using this coefficient, predict on the held out fold, compute the error.&amp;nbsp;&lt;br&gt;3) Average error across all folds for this value for the penalty coefficient.&lt;/div&gt;&lt;div&gt;4) Repeat across all values, use lambda that minimises error.&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="230" x="500" y="770" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
